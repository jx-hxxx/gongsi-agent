# ===== LLM (OpenAI) =====
# https://platform.openai.com 에서 발급
OPENAI_API_KEY=sk-proj-...

# 라우터/요약/QA/거시 = gpt-5.1, 검증 = o4-mini(추론형)
ROUTER_MODEL=gpt-5.1
SUMMARY_MODEL=gpt-5.1
QA_MODEL=gpt-5.1
MACRO_MODEL=gpt-5.1
VERIFICATION_MODEL=o4-mini

# ===== OpenDART (주 데이터) =====
# https://opendart.fss.or.kr 에서 무료 발급 (이메일 즉시, 일 1만건)
DART_API_KEY=

# ===== 한국은행 ECOS (보조: 환율/금리/국고채/KOSPI) =====
ECOS_API_KEY=sample

# ===== 임베딩 (OpenAI) =====
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ===== 검증 임계값 (grounded_score → verdict) =====
VERIFY_PASS_MIN=0.7
VERIFY_PARTIAL_MIN=0.4

# ===== 저장 경로 =====
CHROMA_DIR=./data/chroma       # 벡터DB(코퍼스) 영속 경로
SQLITE_PATH=./data/app.db      # 거시 캐시 등
