{
  "_meta": {
    "purpose": "3-트랙 요약 개선(서술 프롬프트·top_k·선택적 빌드·숫자=RAG 분리)의 회귀 방지·동작 검증용 챗 골든셋",
    "endpoint": "POST /api/v1/chat",
    "schema": {
      "id": "케이스 ID",
      "company": "{corpCode, corpName}",
      "question": "사용자 발화",
      "behavior": "검증 대상 동작(매트릭스의 행)",
      "expect": {
        "intent": "기대 intent (선택)",
        "contains_any": "answerText/sourceContent에 하나 이상 포함되어야 할 문자열들 (선택)",
        "has_number": "콤마 구분 숫자 토큰 포함 여부 (선택)",
        "verdict_not": "이 verdict면 실패 (예: fail) (선택)",
        "out_of_scope": "outOfScope 기대값 (선택)"
      },
      "severity": "must=하드 통과 기준 / watch=알려진 약점·추적용(미통과 허용)",
      "note": "비고"
    },
    "notes": [
      "숫자 기대값은 2024~2025 공시(제56/57기) 기준 관측값. 보고서 갱신 시 값도 갱신 필요.",
      "contains_any 의 숫자는 콤마 구분 핵심부만 사용(원/백만원 접미사는 모델마다 달라 substring 매칭)."
    ]
  },
  "cases": [
    {
      "id": "ss-summary-overview",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 회사 개요 요약해줘",
      "behavior": "요약 트랙 - 회사 개요(서술)",
      "expect": {"intent": "summary", "verdict_not": "fail"},
      "severity": "must",
      "note": "서술 프롬프트로 개요 답변이 나오는지"
    },
    {
      "id": "ss-summary-business",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 사업 내용 요약해줘",
      "behavior": "요약 트랙 - 사업 내용(서술)",
      "expect": {"intent": "summary", "contains_any": ["반도체", "메모리", "디스플레이", "DX", "DS", "가전", "모바일", "하만"]},
      "severity": "must",
      "note": "세그먼트 키워드가 서술에 잡히는지"
    },
    {
      "id": "ss-num-revenue",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 연간 매출액 얼마야?",
      "behavior": "숫자 트랙 - 매출(RAG exact-match)",
      "expect": {"intent": "qa", "contains_any": ["300,870,903", "333,605,938"]},
      "severity": "must",
      "note": "숫자는 RAG로 정확히 (제56기 300,870,903 / 제57기 333,605,938 백만원)"
    },
    {
      "id": "ss-num-opincome",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 영업이익 알려줘",
      "behavior": "숫자 트랙 - 영업이익(RAG exact-match)",
      "expect": {"intent": "qa", "contains_any": ["43,601,051", "32,725,961"]},
      "severity": "must",
      "note": "제57기 43,601,051 / 제56기 32,725,961 백만원"
    },
    {
      "id": "ss-num-assets",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 자산총계 얼마야?",
      "behavior": "숫자 트랙 - 자산총계(RAG exact-match)",
      "expect": {"intent": "qa", "contains_any": ["566,942,110", "514,531,948"]},
      "severity": "must",
      "note": "제57기 566,942,110 / 제56기 514,531,948 백만원"
    },
    {
      "id": "ss-route-business-plain",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "삼성전자 무슨 사업 해?",
      "behavior": "라우팅 견고성 - '요약' 단어 없는 서술 질문",
      "expect": {"intent": "summary", "verdict_not": "fail"},
      "severity": "watch",
      "note": "알려진 약점: 과거 qa로 오라우팅되어 fail한 사례. 라우팅·검색 개선 추적용"
    },
    {
      "id": "ss-scope-other-company",
      "company": {"corpCode": "00126380", "corpName": "삼성전자"},
      "question": "SK하이닉스 작년 영업이익 알려줘",
      "behavior": "스코프 가드 - 다른 회사 질문",
      "expect": {"out_of_scope": true},
      "severity": "must",
      "note": "방에 박힌 기업과 다른 회사 → outOfScope"
    },

    {
      "id": "hd-summary-overview",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 회사 개요 요약해줘",
      "behavior": "요약 트랙 - 회사 개요(서술)",
      "expect": {"intent": "summary", "verdict_not": "fail"},
      "severity": "must",
      "note": "서술 프롬프트로 개요 답변이 나오는지"
    },
    {
      "id": "hd-summary-business",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 사업 내용 요약해줘",
      "behavior": "요약 트랙 - 사업 내용(서술)",
      "expect": {"intent": "summary", "contains_any": ["자동차", "차량", "완성차", "제네시스", "전기차", "모빌리티", "친환경"]},
      "severity": "must",
      "note": "세그먼트 키워드가 서술에 잡히는지"
    },
    {
      "id": "hd-num-revenue",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 연간 매출액 얼마야?",
      "behavior": "숫자 트랙 - 매출(RAG exact-match)",
      "expect": {"intent": "qa", "contains_any": ["175,231,153"]},
      "severity": "must",
      "note": "제57기 175,231,153 백만원 (관측값)"
    },
    {
      "id": "hd-num-opincome",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 영업이익 알려줘",
      "behavior": "숫자 트랙 - 영업이익(RAG, 값 미고정)",
      "expect": {"intent": "qa", "has_number": true, "verdict_not": "fail"},
      "severity": "must",
      "note": "정확값 미관측 → intent=qa + 숫자 포함 + 비실패로 느슨 검증"
    },
    {
      "id": "hd-num-liabilities",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 부채총계 얼마야?",
      "behavior": "숫자 트랙 - 부채총계(RAG, 값 미고정)",
      "expect": {"intent": "qa", "has_number": true, "verdict_not": "fail"},
      "severity": "must",
      "note": "정확값 미관측 → 느슨 검증"
    },
    {
      "id": "hd-route-business-plain",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "현대자동차 무슨 사업 해?",
      "behavior": "라우팅 견고성 - '요약' 단어 없는 서술 질문",
      "expect": {"intent": "summary", "verdict_not": "fail"},
      "severity": "watch",
      "note": "라우팅·검색 개선 추적용"
    },
    {
      "id": "hd-scope-other-company",
      "company": {"corpCode": "00164742", "corpName": "현대자동차"},
      "question": "기아 작년 매출 알려줘",
      "behavior": "스코프 가드 - 다른 회사 질문",
      "expect": {"out_of_scope": true},
      "severity": "must",
      "note": "방에 박힌 기업과 다른 회사 → outOfScope"
    }
  ]
}
